#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2); // LCD address 0x27, 16x2 size

int ledDry = 2;       // LED for dry soil
int ledWet = 4;       // LED for wet soil
int buzzer = 3;       // Buzzer
int sensorPin = A1;   // Soil moisture sensor

void setup() {
  pinMode(ledDry, OUTPUT);
  pinMode(ledWet, OUTPUT);
  pinMode(buzzer, OUTPUT);
  lcd.init();        // Initialize LCD
  lcd.backlight();   // Turn on LCD backlight
  Serial.begin(9600);
}

void loop() {
  int sensorValue = analogRead(sensorPin); // Read sensor
  Serial.println(sensorValue);

  lcd.clear();               // Clear screen
  lcd.setCursor(0,0);
  lcd.print("Moisture:");
  lcd.setCursor(0,1);
  lcd.print(sensorValue);    // Show sensor value

  if (sensorValue < 300) {   // Soil is dry
    digitalWrite(ledDry, HIGH);
    digitalWrite(ledWet, LOW);
    digitalWrite(buzzer, HIGH);
    lcd.setCursor(8,1);
    lcd.print("Dry");
  } 
  else if (sensorValue > 700) { // Soil is wet
    digitalWrite(ledDry, LOW);
    digitalWrite(ledWet, HIGH);
    digitalWrite(buzzer, LOW);
    lcd.setCursor(8,1);
    lcd.print("Wet");
  } 
  else {   // Soil moisture is okay
    digitalWrite(ledDry, LOW);
    digitalWrite(ledWet, LOW);
    digitalWrite(buzzer, LOW);
    lcd.setCursor(8,1);
    lcd.print("OK");
  }

  delay(1000); // Wait 1 second
}
